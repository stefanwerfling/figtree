{
    "logging": {
        "dirname": "./logs",
        "level": "info"
    },
    "db": {
        "redis": {
            "url": "redis://127.0.0.1:6379"
        }
    },
    "httpserver": {
        "port": 3000,
        "publicdir": "./public"
    },
    "cluster": {
        "enabled": true,
        "roles": {
            "http": 2,
            "cron": 1
        },
        "shutdownTimeoutMs": 15000,
        "respawn": {
            "backoffMs": [0, 1000, 5000, 15000, 30000],
            "maxPerWindow": 5,
            "windowMs": 60000
        },
        "sharedStore": {
            "type": "ipc",
            "namespace": "example"
        }
    }
}